{
  "manifest_version": 3,
  "name": "ClaimSense — AI Fact Checker",
  "version": "2.0",
  "description": "Select any text on the web and instantly fact-check it with AI.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClaimSense Fact Checker"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
